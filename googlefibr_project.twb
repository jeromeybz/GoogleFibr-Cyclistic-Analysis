      <column caption='Total Repeat calls' datatype='integer' name='[Calculation_0054727704989696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([contacts_n_1]) + &#13;&#10;SUM([contacts_n_2]) + &#13;&#10;SUM([contacts_n_3]) + &#13;&#10;SUM([contacts_n_4]) +&#13;&#10;SUM([contacts_n_5]) +&#13;&#10;SUM([contacts_n_6]) +&#13;&#10;SUM([contacts_n_7])' />
      </column>
      <column caption='Total calls' datatype='integer' name='[Calculation_0054727709364225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0054727704989696] + SUM([contacts_n])' />
      </column>
      <column caption='percentage of day 0calls' datatype='real' name='[Calculation_0054727723266052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([contacts_n]) / TOTAL(SUM([contacts_n]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
